{
  "agents": {
    "defaults": {
      "workspace": "/app/workspace",
      "model": "coder-model",
      "provider": "custom",
      "max_tool_iterations": 20,
      "temperature": 0.1
    }
  },
  "channels": {
    "webchat": {
      "enabled": true,
      "allow_from": ["*"]
    }
  },
  "gateway": {
    "heartbeat": {
      "enabled": false
    }
  },
  "tools": {
    "exec": {
      "enable": true,
      "timeout": 30
    },
    "mcp_servers": {
      "lms": {
        "type": "stdio",
        "command": "python",
        "args": ["-m", "mcp_lms"]
      }
    }
  }
}
